# Environment variables for the roboarm-backend service.
# Copy to .env for local development. Do NOT commit real values.

# CORS — comma-separated allowed origins (* to allow all)
ROBOARM_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173,http://localhost:4200

# Camera device index or path (e.g. 0, 1, /dev/video0)
ROBOARM_CAMERA_DEVICE=0

# Camera capture resolution
ROBOARM_CAMERA_WIDTH=1280
ROBOARM_CAMERA_HEIGHT=720

# JPEG compression quality for the camera stream (1–100)
ROBOARM_CAMERA_JPEG_QUALITY=80

# --- GitHub Actions secrets (do NOT commit real values) ---
# Add these in: GitHub → Settings → Secrets and variables → Actions

# Docker Hub — used to push the backend container image
DOCKERHUB_USERNAME=your-dockerhub-username
DOCKERHUB_TOKEN=your-dockerhub-access-token
